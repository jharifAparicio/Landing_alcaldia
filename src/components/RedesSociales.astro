---
// src/components/RedesSociales.astro
---

<section id="redes" class="py-20 px-4 max-w-7xl mx-auto">
  <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-4">
    <div>
      <h2 class="text-3xl font-bold text-gray-900 mb-3">
        Sigue la campaña día a día
      </h2>
      <p class="text-lg text-gray-600">
        Acompáñanos en nuestras redes sociales y sé parte del cambio.
      </p>
    </div>
    <a
      href="#"
      class="inline-flex items-center gap-2 bg-blue-600 text-white px-6 py-3 rounded-full font-semibold hover:bg-blue-700 transition-colors shadow-md hover:shadow-lg"
    >
      Ver todo en Instagram
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="2"
        stroke="currentColor"
        class="w-5 h-5"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path>
      </svg>
    </a>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
    <!-- Publicación 1 -->
    <a
      href="#"
      class="group relative block aspect-[4/5] overflow-hidden rounded-2xl bg-gray-100"
    >
      <img
        src="https://images.unsplash.com/photo-1541872516-56da456f9660?q=80&w=800&auto=format&fit=crop"
        alt="Reunión vecinal"
        class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
      />
      <div
        class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-80 transition-opacity group-hover:opacity-90"
      >
      </div>
      <div class="absolute inset-0 p-5 flex flex-col justify-end">
        <div class="flex gap-2 mb-3">
          <span
            class="bg-pink-500/90 text-white text-xs font-bold px-2 py-1 rounded backdrop-blur-sm"
            >Instagram</span
          >
        </div>
        <p class="text-white font-medium text-sm line-clamp-2">
          Hoy estuvimos escuchando a los vecinos del Distrito 2. ¡Juntos
          construiremos una ciudad más segura! 🤝🏙️
        </p>
      </div>
    </a>

    <!-- Publicación 2 -->
    <a
      href="#"
      class="group relative block aspect-[4/5] overflow-hidden rounded-2xl bg-gray-100"
    >
      <img
        src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?q=80&w=800&auto=format&fit=crop"
        alt="Debate jóvenes"
        class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
      />
      <div
        class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-80 transition-opacity group-hover:opacity-90"
      >
      </div>
      <div class="absolute inset-0 p-5 flex flex-col justify-end">
        <div class="flex gap-2 mb-3">
          <span
            class="bg-black/90 text-white text-xs font-bold px-2 py-1 rounded backdrop-blur-sm border border-white/20"
            >TikTok</span
          >
        </div>
        <p class="text-white font-medium text-sm line-clamp-2">
          Nuestras propuestas para los jóvenes y universitarios. #SucreEmprende
          🎓💡
        </p>
      </div>
    </a>

    <!-- Publicación 3 -->
    <a
      href="#"
      class="group relative block aspect-[4/5] overflow-hidden rounded-2xl bg-gray-100"
    >
      <img
        src="https://images.unsplash.com/photo-1577414445328-912a7a5843a8?q=80&w=800&auto=format&fit=crop"
        alt="Recorrido mercado"
        class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
      />
      <div
        class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-80 transition-opacity group-hover:opacity-90"
      >
      </div>
      <div class="absolute inset-0 p-5 flex flex-col justify-end">
        <div class="flex gap-2 mb-3">
          <span
            class="bg-blue-600/90 text-white text-xs font-bold px-2 py-1 rounded backdrop-blur-sm"
            >Facebook</span
          >
        </div>
        <p class="text-white font-medium text-sm line-clamp-2">
          Gran recibimiento en el Mercado Central. Sucre está lista para la
          transformación. 🍎🏢
        </p>
      </div>
    </a>

    <!-- Publicación 4 -->
    <a
      href="#"
      class="group relative block aspect-[4/5] overflow-hidden rounded-2xl bg-gray-100"
    >
      <img
        src="https://images.unsplash.com/photo-1517048676732-d65bc937f952?q=80&w=800&auto=format&fit=crop"
        alt="Conferencia de prensa"
        class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
      />
      <div
        class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-80 transition-opacity group-hover:opacity-90"
      >
      </div>
      <div class="absolute inset-0 p-5 flex flex-col justify-end">
        <div class="flex gap-2 mb-3">
          <span
            class="bg-pink-500/90 text-white text-xs font-bold px-2 py-1 rounded backdrop-blur-sm"
            >Instagram</span
          >
        </div>
        <p class="text-white font-medium text-sm line-clamp-2">
          Presentación oficial de nuestro plan "Ciudad Limpia y Verde". 🌳♻️
        </p>
      </div>
    </a>
  </div>
</section>
