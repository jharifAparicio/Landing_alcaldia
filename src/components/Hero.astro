---
// src/components/Hero.astro
---

<section id="inicio" class="relative bg-gray-50 overflow-hidden py-16 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="lg:grid lg:grid-cols-12 lg:gap-8 items-center">
      <div
        class="sm:text-center md:max-w-2xl md:mx-auto lg:col-span-6 lg:text-left"
      >
        <div
          class="mb-4 inline-flex items-center gap-2 px-4 py-2 rounded-full bg-blue-100/50 border border-blue-200 backdrop-blur-sm sm:mx-auto lg:mx-0"
        >
          <span class="flex h-3 w-3 rounded-full bg-blue-600"></span>
          <span
            class="text-sm font-semibold tracking-wide text-blue-900 uppercase"
            >Movimiento Transformación Sucre</span
          >
        </div>
        <h1
          class="text-4xl tracking-tight font-extrabold text-gray-900 sm:text-5xl md:text-6xl"
        >
          <span
            class="block text-gray-900 text-2xl sm:text-3xl font-medium mb-2"
            >Dr. Carlos Mendoza</span
          >
          <span class="block text-blue-900">Transformemos</span>
          <span class="block text-red-600">nuestra Sucre</span>
        </h1>
        <p
          class="mt-3 text-base text-gray-500 sm:mt-5 sm:text-xl lg:text-lg xl:text-xl"
        >
          Con honestidad, tecnología y trabajo, construiremos la ciudad que
          nuestros hijos merecen. Es momento de un cambio real.
        </p>
        <div
          class="mt-8 sm:max-w-lg sm:mx-auto sm:text-center lg:text-left lg:mx-0"
        >
          <button
            class="px-8 py-3 border border-transparent text-base font-bold rounded-md text-white bg-blue-900 hover:bg-blue-800 md:py-4 md:text-lg md:px-10"
            onclick="window.location.href='#propuestas'"
          >
            Conoce el Plan de Gobierno
          </button>
        </div>
      </div>
      <div
        class="mt-12 relative sm:max-w-lg sm:mx-auto lg:mt-0 lg:max-w-none lg:mx-0 lg:col-span-6 lg:flex lg:items-center"
      >
        <div class="relative mx-auto w-full lg:max-w-md">
          <!-- Fondo decorativo -->
          <div
            class="absolute -inset-4 bg-gradient-to-r from-blue-600 to-cyan-500 rounded-[2.5rem] transform rotate-3 opacity-20 blur-lg"
          >
          </div>
          <div
            class="absolute -inset-4 bg-gradient-to-l from-red-500 to-pink-500 rounded-[2.5rem] transform -rotate-2 opacity-20 blur-lg"
          >
          </div>

          <!-- Contenedor de la foto -->
          <div
            class="relative w-full rounded-[2.5rem] shadow-2xl overflow-hidden aspect-[3/4] border-4 border-white"
          >
            <!-- Imagen del candidato (usando Unsplash como placeholder de un hombre profesional) -->
            <img
              src="https://images.unsplash.com/photo-1560250097-0b93528c311a?q=80&w=800&auto=format&fit=crop"
              alt="Dr. Carlos Mendoza - Candidato"
              class="w-full h-full object-cover object-top"
            />

            <!-- Etiqueta sobre la foto -->
            <div
              class="absolute bottom-6 left-6 right-6 bg-white/90 backdrop-blur-md rounded-2xl p-4 shadow-xl border border-white/50 transform translate-y-2 hover:-translate-y-1 transition-transform"
            >
              <p
                class="text-xs font-bold text-gray-500 uppercase tracking-widest mb-1"
              >
                Candidato a Alcalde
              </p>
              <p class="text-xl font-extrabold text-gray-900 leading-none">
                Carlos Mendoza 2026
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
