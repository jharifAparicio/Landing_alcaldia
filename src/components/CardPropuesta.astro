---
// src/components/CardPropuesta.astro
interface Props {
  title: string;
  description: string;
  image: string;
}

const { title, description, image } = Astro.props;
---

<div
  class="group relative h-96 rounded-[2rem] overflow-hidden shadow-sm hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1"
>
  <!-- Imagen de fondo -->
  <img
    src={image}
    alt={title}
    class="absolute inset-0 w-full h-full object-cover transition-transform duration-700"
  />

  <!-- Gradiente para que el texto sea legible -->
  <div
    class="absolute inset-0 bg-gradient-to-t from-gray-900/95 via-gray-900/60 to-transparent"
  >
  </div>

  <!-- Contenido -->
  <div class="absolute inset-0 p-8 flex flex-col justify-end">
    <h3 class="text-2xl font-bold text-white mb-2 leading-tight">{title}</h3>
    <p class="text-gray-200 leading-relaxed text-sm opacity-90">
      {description}
    </p>
  </div>
</div>
